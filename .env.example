# ─────────────────────────────────────────────────────────────────────────────
# CineLang — Backend environment (.env)
# Copy to .env and fill in all values before running deploy.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://cinelang.linuslearning.in

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs:
#   https://cinelang.linuslearning.in/api/auth/callback/google
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-from-aistudio

# ── OpenSubtitles ─────────────────────────────────────────────────────────────
# Free registration at https://www.opensubtitles.com/en/consumers
# Docs: https://api.opensubtitles.com/api/v1/
OPENSUBS_API_KEY=your-opensubtitles-api-key

# ── JWT signing secret ────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=generate_a_random_64_char_hex_string

# ── NextAuth secret ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=generate_a_random_32_char_base64_string
