# ─────────────────────────────────────────────────────────────────────────────
# CineLang — Next.js frontend environment
# Local dev: copy to .env.local  |  Production: set via docker-compose.yml
# ─────────────────────────────────────────────────────────────────────────────

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Authorized redirect URIs must include: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Production: https://cinelang.linuslearning.in
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# ── Backend URLs ──────────────────────────────────────────────────────────────
# Client-side: must be reachable from the browser
# Prod: same origin (https://cinelang.linuslearning.in) — Nginx routes /api/ to FastAPI
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side NextAuth JWT callback (direct FastAPI, no Nginx)
# Prod: http://backend:8000  (Docker service name) or http://localhost:8000
BACKEND_URL=http://localhost:8000
